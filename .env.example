# ======================================================================
# digital-world.dev Hermes Agent Traefik Stack
# Copy to .env and adjust values.
# ======================================================================

COMPOSE_PROJECT_NAME=digitalworld-hermes

# Public dashboard domain
HERMES_DOMAIN=hermes.digital-world.dev

# Optional public API domain, only used with compose/docker-compose.api-router.yml
HERMES_API_DOMAIN=api.hermes.digital-world.dev

# Existing Traefik setup
TRAEFIK_NETWORK=proxy
TRAEFIK_ENTRYPOINT=websecure
TRAEFIK_CERTRESOLVER=le

# Traefik Basic Auth user string.
# Generate with:
# docker run --rm httpd:2.4-alpine htpasswd -nbB admin 'CHANGE_ME' | sed -e 's/\$/\$\$/g'
TRAEFIK_BASIC_AUTH_USERS=admin:$$2y$$05$$REPLACE_THIS_HASH

# Hermes
HERMES_IMAGE=nousresearch/hermes-agent:latest
HERMES_DASHBOARD_TUI=0
GATEWAY_ALLOW_ALL_USERS=true
API_SERVER_KEY=CHANGE_ME_WITH_OPENSSL_RAND_HEX_32
TZ=Europe/Berlin

# digital-world.dev labels
DW_OWNER=digital-world.dev
DW_SERVICE=hermes-agent
DW_ENV=prod
DW_MAINTAINER=kontakt@digital-world.dev
